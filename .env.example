# ─── Backend ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Database
DB_HOST=database
DB_PORT=3306
DB_NAME=carre_ivoire
DB_USER=carre_user
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme_root

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRATION=24h
REFRESH_TOKEN_SECRET=your-refresh-token-secret-minimum-32-characters
REFRESH_TOKEN_EXPIRATION=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# CORS
FRONTEND_URL=http://localhost:5173

# Mail
MAIL_FROM=contact@carre-ivoire.fr

# Seeder admin (npx sequelize-cli db:seed:all)
ADMIN_EMAIL=admin@carre-ivoire.fr
ADMIN_PASSWORD=Admin1234!

# ─── Frontend ────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api/v1
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
