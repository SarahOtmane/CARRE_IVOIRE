# ============================================================
# Carré Ivoire — Variables d'environnement
# Copier ce fichier : cp .env.example .env
# ============================================================

# ── Base de données ──────────────────────────────────────────
DB_HOST=database
DB_PORT=3306
DB_NAME=carre_ivoire
DB_USER=carre_user
DB_PASSWORD=changeme_secure_password_here
DB_ROOT_PASSWORD=changeme_root_password_here

# ── API (NestJS) ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Authentification JWT ─────────────────────────────────────
# Générer un secret : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate_a_32char_minimum_secret_here_xxxxxxxxxx
JWT_EXPIRATION=24h
REFRESH_TOKEN_SECRET=generate_a_different_32char_minimum_secret_xxxxxx
REFRESH_TOKEN_EXPIRATION=7d

# ── CORS ─────────────────────────────────────────────────────
# URLs autorisées par le backend (séparer par virgule)
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ── Stripe ───────────────────────────────────────────────────
# Tableau de bord : https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Écouter les webhooks en local :
# stripe listen --forward-to localhost:3000/api/v1/stripe/webhook

# ── Frontend (variables injectées par Vite) ──────────────────
VITE_API_URL=http://localhost:3000/api/v1
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Admin initial (utilisé par le seeder) ────────────────────
# docker compose exec backend npx sequelize-cli db:seed:all
ADMIN_EMAIL=admin@carre-ivoire.fr
ADMIN_PASSWORD=Admin1234!

# ── Emails (optionnel) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
MAIL_FROM=contact@carre-ivoire.fr

# ── Logs ─────────────────────────────────────────────────────
LOG_LEVEL=debug
