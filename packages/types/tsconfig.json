{
  "extends": "@carre-ivoire/config/typescript/base",
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "moduleResolution": "bundler",
    "declaration": true,
    "outDir": "./dist",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
