{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "module": "commonjs",
    "target": "ES2021",
    "declaration": true,
    "declarationMap": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "strict": true,
    "noImplicitAny": true,
    "noFallthroughCasesInSwitch": true
  }
}
